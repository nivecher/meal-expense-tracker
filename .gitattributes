# Auto detect text files and normalize line endings
* text=auto eol=lf

# Explicitly declare text files you want to always be normalized and converted
# to native line endings on checkout
*.py text
*.md text
*.txt text
*.toml text
*.ini text
*.cfg text
*.json text
*.yaml text
*.yml text
*.sh text eol=lf

# Denote all files that are truly binary and should not be modified
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary
*.zip binary
*.gz binary
*.tar binary
*.exe binary
*.dll binary
*.so binary
*.dylib binary
*.pyd binary
*.pyc binary
*.pyo binary
*.pyd binary
*.whl binary
*.egg binary

# Python files should use LF line endings
*.py text eol=lf

# Shell scripts should use LF line endings
*.sh text eol=lf

# Windows batch files should use CRLF line endings
*.bat text eol=crlf
*.cmd text eol=crlf

# SQL files should use LF line endings
*.sql text eol=lf

# HTML, CSS, and JavaScript files should use LF line endings
*.html text eol=lf
*.css text eol=lf
*.js text eol=lf
*.ts text eol=lf
*.jsx text eol=lf
*.tsx text eol=lf

# Markdown files should always use LF line endings
*.md text eol=lf

# Git configuration files
.gitattributes export-ignore
.gitignore export-ignore
.gitmodules export-ignore

# Python packaging and distribution files
*.egg-info/ export-ignore
*.egg export-ignore
*.pyc export-ignore
__pycache__/ export-ignore
*.py[cod] export-ignore
*$py.class export-ignore

# Virtual environment
.venv/ export-ignore
venv/ export-ignore
env/ export-ignore
ENV/ export-ignore

# IDE and editor files
.vscode/ export-ignore
.idea/ export-ignore
*.swp export-ignore
*.swo export-ignore
*~ export-ignore
.DS_Store export-ignore

# Build and distribution
dist/ export-ignore
build/ export-ignore
*.egg-info/ export-ignore
*.egg export-ignore

# Testing and coverage
.coverage export-ignore
htmlcov/ export-ignore
.pytest_cache/ export-ignore
.mypy_cache/ export-ignore

# Local development
.env export-ignore
.env.local export-ignore
.env.*.local export-ignore

# Documentation
docs/_build/ export-ignore
