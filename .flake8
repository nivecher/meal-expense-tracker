[flake8]
# Set the maximum line length
exclude = .git,__pycache__,build,dist,migrations,.tox,.venv,venv,*.egg-info,.env,.pytest_cache,.mypy_cache,cache
max-line-length = 120

# Ignore specific errors
# E402 - module level import not at top of file (handled by isort)
# W291 - trailing whitespace
# W293 - blank line contains whitespace
# W391 - blank line at end of file

# Ignore specific files
per-file-ignores =
    # Allow imports after code in migration files
    */migrations/*.py: E402
    # Allow unused imports in __init__.py files
    */__init__.py: F401
    # Ignore specific files with known issues
    scripts/invoke_migrations.py: F401, E402
    migrate_db.py: E402, W291, W293, W391
    # Test specific ignores
    tests/*: S101
    # App specific ignores
    app.py: F841

# Import sorting
import-order-style = google

# Code complexity
max-complexity = 10
max-args = 5
max-locals = 15
max-statements = 50
max-branches = 12
max-returns = 6
max-attributes = 7

# Docstring style
docstring-convention = google
